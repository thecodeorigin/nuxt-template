# =============================================================================
# Public runtime config (exposed to the client — never put secrets here)
# =============================================================================
NUXT_PUBLIC_BASE_DOMAIN=localhost:3002
NUXT_PUBLIC_SSL_ENABLED=false
NUXT_PUBLIC_DEMO_MODE=false

# Server-side gate for dev/demo-only auth routes and module stripping
# (eslint/test-utils/nuxt-security). Keep `false` outside the demo deploy.
NUXT_DEMO_MODE=false

# =============================================================================
# Auth secrets — generate with `pnpm auth:generate`
# =============================================================================
NUXT_AUTH_SECRET=
NUXT_TASK_SECRET=
NUXT_WEBHOOK_SIGNING_SECRET=

# Bearer token guarding /api/cron/** ; leave empty locally.
CRON_SECRET=

# =============================================================================
# NuxtHub storage (database / KV / blob / cache)
# -----------------------------------------------------------------------------
# NUXT_HUB_CLOUDFLARE_ACCOUNT_ID=
# NUXT_HUB_CLOUDFLARE_API_TOKEN=
# NUXT_HUB_CLOUDFLARE_DATABASE_ID=
# =============================================================================

# =============================================================================
# SMTP — point at your own mail server. For local dev, run a catch-all SMTP
# such as Mailpit (`docker run -p 1025:1025 -p 8025:8025 axllent/mailpit`)
# and set the port to 1025.
# =============================================================================
NUXT_SMTP_HOST=localhost
NUXT_SMTP_PORT=1025
NUXT_SMTP_USER=
NUXT_SMTP_PASS=
NUXT_SMTP_FROM="Nuxt Template <noreply@localhost>"

NUXT_CUSTOMER_SUPPORT_EMAIL=

# =============================================================================
# OAuth providers
# =============================================================================
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=

NUXT_GITHUB_CLIENT_ID=
NUXT_GITHUB_CLIENT_SECRET=

# =============================================================================
# SePay (Vietnamese bank transfer payments)
# =============================================================================
NUXT_SEPAY_TRANSACTION_PREFIX=
NUXT_SEPAY_BANK_NUMBER=
NUXT_SEPAY_BANK_NAME=
