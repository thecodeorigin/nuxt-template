# =============================================================================
# Public runtime config (exposed to the client — never put secrets here)
# =============================================================================
NUXT_PUBLIC_BASE_DOMAIN=localhost:3002
NUXT_PUBLIC_SSL_ENABLED=false
NUXT_PUBLIC_DEMO_MODE=false

# Server-side gate for dev/demo-only auth routes and module stripping
# (eslint/test-utils/nuxt-security). Keep `false` outside the demo deploy.
NUXT_DEMO_MODE=false

# =============================================================================
# Auth secrets — generate with `pnpm auth:generate`
# =============================================================================
NUXT_AUTH_SECRET=
NUXT_TASK_SECRET=
NUXT_WEBHOOK_SIGNING_SECRET=

# Vercel injects this for scheduled functions; leave empty locally.
CRON_SECRET=

# =============================================================================
# Postgres (Drizzle + Nitro)
# Prefer the URL; the per-field block is only used when URL is unset.
# Defaults below point at the docker-compose `postgres` service.
# =============================================================================
NUXT_POSTGRES_URL=postgresql://postgres:postgres@localhost:15432/postgres
NUXT_POSTGRES_SSL=false

# NUXT_POSTGRES_HOST=localhost
# NUXT_POSTGRES_PORT=15432
# NUXT_POSTGRES_USER=postgres
# NUXT_POSTGRES_PASSWORD=postgres
# NUXT_POSTGRES_DB=postgres

# =============================================================================
# Redis — pick ONE: Upstash REST (prod) or self-hosted (local docker)
# =============================================================================
# Upstash (production / preview)
NUXT_UPSTASH_REDIS_REST_URL=
NUXT_UPSTASH_REDIS_REST_TOKEN=

# Self-hosted (local docker-compose `redis` service)
NUXT_REDIS_HOST=localhost
NUXT_REDIS_PORT=16379
NUXT_REDIS_PASSWORD=redis

# Override the key prefix; defaults to redis:local / redis:preview:<slug> / redis:prod
# NUXT_REDIS_BASE=

# Upstash management API (only needed for programmatic Upstash ops)
NUXT_UPSTASH_EMAIL=
NUXT_UPSTASH_API_KEY=

# =============================================================================
# MongoDB (optional — only enabled when all three are set)
# =============================================================================
NUXT_MONGODB_URI=mongodb://root:password@localhost:37017
NUXT_MONGODB_DATABASE_NAME=nuxt-template
NUXT_MONGODB_COLLECTION_NAME=storage

# =============================================================================
# SMTP — defaults target the docker-compose `mailhog` service
# =============================================================================
NUXT_SMTP_HOST=localhost
NUXT_SMTP_PORT=11025
NUXT_SMTP_USER=
NUXT_SMTP_PASS=
NUXT_SMTP_FROM="Nuxt Template <noreply@localhost>"

NUXT_CUSTOMER_SUPPORT_EMAIL=

# =============================================================================
# OAuth providers
# =============================================================================
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=

NUXT_GITHUB_CLIENT_ID=
NUXT_GITHUB_CLIENT_SECRET=

# =============================================================================
# SePay (Vietnamese bank transfer payments)
# =============================================================================
NUXT_SEPAY_TRANSACTION_PREFIX=
NUXT_SEPAY_BANK_NUMBER=
NUXT_SEPAY_BANK_NAME=

# =============================================================================
# docker-compose.services.yml — host port + credential overrides
# (consumed by docker-compose, NOT by Nuxt; safe to leave at defaults)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=15432

REDIS_PASSWORD=redis
REDIS_PORT=16379
REDISINSIGHT_PORT=15540

MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=password
MONGO_PORT=37017

SMTP_PORT=11025
SMTP_WEB_PORT=18025
