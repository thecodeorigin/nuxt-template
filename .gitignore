# Nuxt dev/build outputs
.output
.data
.nuxt
.nitro
.cache
.docker
dist

# Node dependencies
node_modules

# Logs
logs
*.log

# Misc
.DS_Store
.fleet
.idea

# Local env files
.env
.env.*
!.env.example

# Test coverage
coverage/

# Playwright
playwright-report/
test-results/

# Claude Code — .claude is a Windows junction to .agents (source of truth).
# Git follows junctions as regular dirs, so we ignore .claude entirely;
# all tracked content lives under .agents/ instead.
.claude

# Agent-team runtime state (regenerated per session)
.agents/teams/
.agents/tasks/

# Per-developer settings (project default lives in .agents/settings.json)
.agents/settings.local.json

# Agent run artifacts (QA + UX screenshots, reports, lighthouse output)
.agents/runs/

# Prep skill plan outputs and agent workspace artifacts
.agents/plans/
.agents/workspace/
ux/
screenshots/

.wrangler
